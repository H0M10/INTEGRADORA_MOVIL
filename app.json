{
  "expo": {
    "name": "NovaGuardian",
    "slug": "novaguardian",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novaguardian.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NovaGuardian necesita acceso a tu ubicación para mostrar la ubicación de tus seres queridos en tiempo real.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NovaGuardian necesita acceso a tu ubicación para rastrear la ubicación de tus seres queridos incluso cuando la app está en segundo plano.",
        "NSCameraUsageDescription": "NovaGuardian necesita acceso a la cámara para escanear códigos QR de dispositivos.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.novaguardian.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1E3A5F",
          "sounds": [
            "./assets/sounds/alert.wav"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "NovaGuardian necesita acceso a tu ubicación para monitorear a tus seres queridos.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "env": "production",
      "apiUrl": "https://backend-production-2148.up.railway.app/api/v1",
      "eas": {
        "projectId": "058c9de4-f785-402f-bf6b-26a524651fa4"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "homsa"
  }
}

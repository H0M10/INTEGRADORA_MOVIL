# Entorno: development | staging | production
APP_ENV=production

CZ

# WebSocket URL
WS_URL=wss://backend-production-2148.up.railway.app/ws

# Para desarrollo local (descomentar y cambiar según tu IP)
# API_URL=http://10.13.0.8:8002/api/v1
# WS_URL=ws://10.13.0.8:8002/ws

# EAS Project ID (obtener de expo.dev)
EAS_PROJECT_ID=your-project-id

# Google Services (para notificaciones push Android)
# Necesitas crear un proyecto en Firebase Console
GOOGLE_SERVICES_FILE=./google-services.json
